# ──────────────────────────────────────────────────────────────────────────
# AI Project Architect — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ──────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────
APP_NAME="AI Project Architect API"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development    # development | staging | production

# ─── Serveur ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Base de données — PostgreSQL ─────────────────────────────────────────
# Driver psycopg v3 (postgresql+psycopg) — recommandé SQLAlchemy 2.x
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/ai_project_architect
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false    # true pour logger les requêtes SQL (debug uniquement)

# ─── IA — Groq ────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.7

# ─── Cache (FUTUR — Redis) ────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=3600

# ─── Auth JWT (FUTUR) ─────────────────────────────────────────────────────
# SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
